# Copy this file to ".env" and fill in real values.
# The defaults below match docker-compose.yml, so locally you can leave them as-is.

# Postgres (from docker-compose)
DATABASE_URL="postgresql://sakse:sakse@localhost:5432/sakse?schema=public"

# Redis (from docker-compose) — used by BullMQ for timers/jobs
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000

# --- Wash cycle timing (used by the background worker) ---
# How long one cycle-"minute" really lasts, in ms.
#   60000  = real minutes (production)
#   1000   = seconds (demo: a "40-minute" wash finishes in 40s so you can watch it)
TIME_UNIT_MS=60000
NOTIFY_BEFORE_MINUTES=5   # notify this many minutes before done
GRACE_MINUTES=10          # grace after done before a late fine
FINE_AMOUNT=2000          # late fine in satang (฿20)

# No-show auto-cancel: if the user doesn't scan to start within this many REAL
# minutes of reserving, the hold is cancelled + refunded. (Not sped up by
# TIME_UNIT_MS.) Lower it (e.g. 1) to demo the auto-cancel quickly.
RESERVE_EXPIRE_MINUTES=10
